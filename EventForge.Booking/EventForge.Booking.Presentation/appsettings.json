{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "ConnectionStrings": {
        "DefaultConnection": ""
    },

    "JwtSettings": {
        "SchemeName": "EventForgeScheme",
        "Secret": "SuperSecretKeyWithMoreThan32CharactersLength!!",
        "Issuer": "EventForge",
        "Audience": "EventForgeAPI",
        "Lifetime": 2
    },
    "BookingOptions": {
        "MaxBookingCount": 10
    },
    "KafkaOptions": {
        "BootstrapServers": "localhost:9092",
        "ConsumerGroup": "eventforge-booking"
    },

    "AllowedHosts": "*",

    "Otel": {
        "OtlpEndpoint": "http://localhost:4317"
    },
    "Serilog": {
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning"
            }
        }
    }
}
