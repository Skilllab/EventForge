{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "ConnectionStrings": {
        "DefaultConnection": "Host=localhost;Port=5437;Database=eventforge_events_dev;Username=postgres;Password=postgres",
        "Redis": "localhost:6379"
    },
    "JwtSettings": {
        "SchemeName": "EventForgeScheme",
        "Secret": "SuperSecretKeyWithMoreThan32CharactersLength!!",
        "Issuer": "EventForge",
        "Audience": "EventForgeAPI",
        "Lifetime": 2
    },
    "KafkaOptions": {
        "BootstrapServers": "localhost:9092",
        "ConsumerGroup": "eventforge-events"
    },
    "RedisOptions": {
        "SingleEventExpirationMinutes": 5,
        "TopEventsExpirationMinutes": 10
    },
    "Otlp": {
        "Endpoint": "http://localhost:4317"
    },
    "Serilog": {
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning"
            }
        }
    }

}
