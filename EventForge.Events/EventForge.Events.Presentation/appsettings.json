{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "ConnectionStrings": {
        "DefaultConnection": "",
        "Redis": "localhost:6379"
    },

    "JwtSettings": {
        "SchemeName": "EventForgeScheme",
        "Secret": "SuperSecretKeyWithMoreThan32CharactersLength!!",
        "Issuer": "EventForge",
        "Audience": "EventForgeAPI",
        "Lifetime": 2
    },
    "KafkaOptions": {
        "BootstrapServers": "localhost:9092",
        "ConsumerGroup": "eventforge-events"
    },
    "RedisOptions": {
        "SingleEventExpirationMinutes": 5,
        "TopEventsExpirationMinutes": 10
    },
    "AllowedHosts": "*",

    "Otlp": {
        "Endpoint": "http://localhost:4317"
    },
    "Serilog": {
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning"
            }
        }
    }
}
